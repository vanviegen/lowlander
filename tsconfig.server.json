{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2020", "ESNext.WeakRef", "ESNext.Iterator"],
    "types": ["bun"],
    "declaration": true,
    "declarationMap": true,
    "outDir": "./build",
    "rootDir": ".",
    "paths": {
      "lowlander/server": ["./server/server.ts"]
    }
  },
  "include": ["server/**/*.ts", "examples/**/server/**/*.ts", "tests/fake-warpsocket.ts"],
  "exclude": ["node_modules", "build", "tests"]
}
